{
  "name": "favewise",
  "description": "Make bookmarks useful again",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/joyxhq/favewise#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joyxhq/favewise.git"
  },
  "bugs": {
    "url": "https://github.com/joyxhq/favewise/issues"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "keywords": [
    "bookmarks",
    "browser-extension",
    "chrome-extension",
    "edge-extension",
    "firefox-extension",
    "wxt",
    "local-first",
    "privacy"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "gen:icons": "node scripts/gen-icons.mjs",
    "gen:store-assets": "node scripts/gen-store-assets.mjs",
    "lint:firefox": "npx --yes addons-linter .output/favewise-1.0.0-firefox.zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "bash scripts/e2e-drive.sh",
    "e2e:edge": "node tests/e2e/edge-import-smoke.mjs",
    "verify:release": "pnpm compile && pnpm test && pnpm audit --audit-level moderate && pnpm build && pnpm zip",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "@wxt-dev/module-react": "^1.2.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "wxt": "^0.20.25"
  },
  "pnpm": {
    "overrides": {
      "defu": "^6.1.5",
      "node-notifier>uuid": "^11.1.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "spawn-sync"
    ]
  }
}
